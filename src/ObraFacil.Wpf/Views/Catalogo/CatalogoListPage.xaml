<Page x:Class="ObraFacil.Wpf.Views.Catalogo.CatalogoListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Catálogo">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <!-- Cabeçalho -->
        <TextBlock Grid.Row="0" Text="Catálogo de Itens" FontSize="18" FontWeight="SemiBold"
                   Margin="0,0,0,12"/>

        <!-- Filtros + botão -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBox Text="{Binding Busca, UpdateSourceTrigger=PropertyChanged}"
                     Width="240" Margin="0,0,12,0" ToolTip="Buscar por nome ou categoria..."/>
            <ComboBox Width="130"
                      ItemsSource="{Binding TipoOpcoes}"
                      SelectedItem="{Binding TipoFiltro}"
                      DisplayMemberPath="Label"
                      Margin="0,0,12,0"/>
            <Button Content="+ Novo Item"
                    Command="{Binding NovoItemCommand}"
                    Background="#1976D2" Foreground="White" BorderThickness="0" Padding="10,4"/>
        </StackPanel>

        <!-- Grade -->
        <DataGrid Grid.Row="2" ItemsSource="{Binding Itens}" SelectedItem="{Binding Selecionado}"
                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nome"       Binding="{Binding Nome}"           Width="*"/>
                <DataGridTextColumn Header="Tipo"       Binding="{Binding Tipo}"            Width="90"/>
                <DataGridTextColumn Header="Unidade"    Binding="{Binding Unidade}"         Width="90"/>
                <DataGridTextColumn Header="Preço (R$)" Binding="{Binding PrecoUnitario, StringFormat=C2}" Width="100"/>
                <DataGridTextColumn Header="Categoria"  Binding="{Binding Categoria}"       Width="130"/>
                <DataGridCheckBoxColumn Header="Ativo"  Binding="{Binding Ativo}"           Width="60"/>
                <DataGridTemplateColumn Header="Ações" Width="140">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Editar" Margin="2"
                                        Command="{Binding DataContext.EditarItemCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                        CommandParameter="{Binding}"/>
                                <Button Content="Excluir" Margin="2" Foreground="Red"
                                        Command="{Binding DataContext.ExcluirItemCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                        CommandParameter="{Binding}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
