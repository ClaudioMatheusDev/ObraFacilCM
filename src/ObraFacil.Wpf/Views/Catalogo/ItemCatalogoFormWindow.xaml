<Window x:Class="ObraFacil.Wpf.Views.Catalogo.ItemCatalogoFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Item do Catálogo" Height="400" Width="460"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="TxtTitulo" Text="Novo Item"
                   FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Nome *" FontWeight="SemiBold"/>
            <TextBox x:Name="TxtNome" Margin="0,0,0,10"/>

            <TextBlock Text="Tipo *" FontWeight="SemiBold"/>
            <ComboBox x:Name="CboTipo" Margin="0,0,0,10"/>

            <TextBlock Text="Unidade *" FontWeight="SemiBold"/>
            <ComboBox x:Name="CboUnidade" Margin="0,0,0,10"/>

            <TextBlock Text="Preço Unitário (R$) *" FontWeight="SemiBold"/>
            <TextBox x:Name="TxtPreco" Margin="0,0,0,10"/>

            <TextBlock Text="Categoria" FontWeight="SemiBold"/>
            <TextBox x:Name="TxtCategoria" Margin="0,0,0,10"/>

            <TextBlock Text="Descrição" FontWeight="SemiBold"/>
            <TextBox x:Name="TxtDescricao" Height="50" TextWrapping="Wrap" AcceptsReturn="True"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancelar" Width="80" Margin="0,0,8,0" Click="BtnCancelar_Click"/>
            <Button Content="Salvar" Width="80" Click="BtnSalvar_Click"
                    Background="#1976D2" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
