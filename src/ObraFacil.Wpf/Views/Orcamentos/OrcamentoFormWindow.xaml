<Window x:Class="ObraFacil.Wpf.Views.Orcamentos.OrcamentoFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Orçamento" Height="700" Width="900"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding Title}" Style="{StaticResource LabelDestaque}"
                   FontSize="17" Margin="0,0,0,16"/>

        <!-- Cabeçalho do orçamento -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                <TextBlock Text="Cliente *" FontWeight="SemiBold"/>
                <ComboBox ItemsSource="{Binding Clientes}" DisplayMemberPath="Nome"
                          SelectedItem="{Binding ClienteSelecionado}"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="0,0,8,0">
                <TextBlock Text="Validade" FontWeight="SemiBold"/>
                <DatePicker SelectedDate="{Binding DataValidade}"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Desconto global (R$)" FontWeight="SemiBold"/>
                <TextBox Text="{Binding Desconto}"/>
            </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,8,8,0">
                <TextBlock Text="Condições de pagamento" FontWeight="SemiBold"/>
                <TextBox Text="{Binding CondicoesPagamento}"/>
            </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,8,0,0">
                <TextBlock Text="Observações" FontWeight="SemiBold"/>
                <TextBox Text="{Binding Observacoes}" Height="48" TextWrapping="Wrap" AcceptsReturn="True"/>
            </StackPanel>
        </Grid>

        <!-- Itens do orçamento -->
        <GroupBox Grid.Row="2" Header="Itens" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Content="+ Do catálogo" Style="{StaticResource BtnPrimary}" Margin="0,0,8,0"
                            Command="{Binding AdicionarDoCatalogoCommand}"/>
                    <Button Content="+ Item avulso" Style="{StaticResource BtnSecondary}"
                            Command="{Binding AdicionarAvulsoCommand}"/>
                </StackPanel>
                <DataGrid Grid.Row="1" ItemsSource="{Binding Itens}" CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Descrição"    Binding="{Binding Descricao}"    Width="*" />
                        <DataGridTextColumn Header="Unidade"      Binding="{Binding Unidade}"      Width="80" />
                        <DataGridTextColumn Header="Qtd"          Binding="{Binding Quantidade, StringFormat=N2}"    Width="70" />
                        <DataGridTextColumn Header="Valor Unit."  Binding="{Binding PrecoUnitario, StringFormat=C2}" Width="110" />
                        <DataGridTextColumn Header="Desc. Item"   Binding="{Binding DescontoItem, StringFormat=C2}"  Width="100" />
                        <DataGridTextColumn Header="Subtotal"     Binding="{Binding Subtotal, StringFormat=C2}"      Width="110" />
                        <DataGridTemplateColumn Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="✕" Background="Transparent" BorderThickness="0"
                                            Foreground="Red" Cursor="Hand"
                                            Command="{Binding DataContext.RemoverItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </GroupBox>

        <!-- Totais -->
        <StackPanel Grid.Row="3" HorizontalAlignment="Right" Margin="0,8,0,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Subtotal: " FontWeight="SemiBold" Width="100"/>
                <TextBlock Text="{Binding Subtotal, StringFormat=C2}" Width="120" TextAlignment="Right"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Desconto: " Width="100"/>
                <TextBlock Text="{Binding Desconto, StringFormat=C2}" Width="120" TextAlignment="Right" Foreground="Red"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="TOTAL: " FontWeight="Bold" FontSize="15" Width="100"/>
                <TextBlock Text="{Binding TotalFinal, StringFormat=C2}" FontWeight="Bold" FontSize="15" Width="120" TextAlignment="Right" Foreground="#1976D2"/>
            </StackPanel>
        </StackPanel>

        <!-- Botões -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancelar" Style="{StaticResource BtnSecondary}" Margin="0,0,8,0"
                    Click="BtnCancelar_Click"/>
            <Button Content="Salvar"   Style="{StaticResource BtnPrimary}"
                    Command="{Binding SalvarCommand}"/>
        </StackPanel>
    </Grid>
</Window>
