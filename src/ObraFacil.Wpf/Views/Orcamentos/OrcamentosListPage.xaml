<Page x:Class="ObraFacil.Wpf.Views.Orcamentos.OrcamentosListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:enums="clr-namespace:ObraFacil.Domain.Enums;assembly=ObraFacil.Domain"
      Title="Orçamentos">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título + Novo -->
        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Orçamentos" Style="{StaticResource LabelDestaque}" FontSize="20" VerticalAlignment="Center"/>
            <Button Content="+ Novo Orçamento" Style="{StaticResource BtnPrimary}" HorizontalAlignment="Right"
                    Command="{Binding NovoOrcamentoCommand}" />
        </DockPanel>

        <!-- Filtros -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12" >
            <TextBox Text="{Binding Busca, UpdateSourceTrigger=PropertyChanged}"
                     Width="260" Margin="0,0,12,0" ToolTip="Buscar por número ou cliente..." />
            <ComboBox Width="140"
                      ItemsSource="{Binding StatusOpcoes}"
                      SelectedItem="{Binding StatusFiltro}"
                      DisplayMemberPath="Label"
                      ToolTip="Filtrar por status"/>
        </StackPanel>

        <!-- Grid -->
        <DataGrid Grid.Row="2" ItemsSource="{Binding Orcamentos}" SelectedItem="{Binding Selecionado}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Número"  Binding="{Binding Numero}"      Width="110" />
                <DataGridTextColumn Header="Cliente" Binding="{Binding ClienteNome}" Width="*" />
                <DataGridTextColumn Header="Status"  Binding="{Binding Status, Converter={StaticResource StatusConverter}}" Width="100" />
                <DataGridTextColumn Header="Emissão" Binding="{Binding DataEmissao, StringFormat=dd/MM/yyyy}" Width="100" />
                <DataGridTextColumn Header="Total"   Binding="{Binding TotalFinal, StringFormat=C2}" Width="110" />
                <DataGridTemplateColumn Header="Ações" Width="220">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="Editar" Margin="2" Padding="8,3"
                                        Command="{Binding DataContext.EditarOrcamentoCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                        CommandParameter="{Binding}" />
                                <Button Content="PDF" Margin="2" Padding="8,3"
                                        Background="#FF9800" Foreground="White" BorderThickness="0"
                                        Command="{Binding DataContext.GerarPdfCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                        CommandParameter="{Binding}" />
                                <Button Content="Excluir" Margin="2" Padding="8,3"
                                        Style="{StaticResource BtnDanger}"
                                        Command="{Binding DataContext.ExcluirOrcamentoCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                        CommandParameter="{Binding}" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Rodapé busy -->
        <TextBlock Grid.Row="3" Text="Carregando..." Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                   Foreground="Gray" Margin="0,8,0,0"/>
    </Grid>
</Page>
