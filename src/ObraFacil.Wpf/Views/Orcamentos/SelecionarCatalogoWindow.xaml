<Window x:Class="ObraFacil.Wpf.Views.Orcamentos.SelecionarCatalogoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Selecionar do Catálogo" Height="420" Width="600"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBox Grid.Row="0" x:Name="TxtBusca" Margin="0,0,0,8"
                 TextChanged="TxtBusca_TextChanged" ToolTip="Filtrar..."/>

        <DataGrid Grid.Row="1" x:Name="Grid" AutoGenerateColumns="False"
                  CanUserAddRows="False" SelectionMode="Single"
                  MouseDoubleClick="Grid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nome"     Binding="{Binding Nome}"     Width="*"/>
                <DataGridTextColumn Header="Unidade"  Binding="{Binding Unidade}"  Width="80"/>
                <DataGridTextColumn Header="Preço"    Binding="{Binding PrecoUnitario, StringFormat=C2}" Width="100"/>
                <DataGridTextColumn Header="Categoria" Binding="{Binding Categoria}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancelar" Width="80" Margin="0,0,8,0" Click="BtnCancelar_Click"/>
            <Button Content="Selecionar" Width="90" Click="BtnSelecionar_Click"
                    Background="#1976D2" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
